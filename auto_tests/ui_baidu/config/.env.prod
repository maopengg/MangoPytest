# -*- coding: utf-8 -*-
# 百度 UI 测试 - 生产环境配置（百度官网）

ENV=prod
BASE_URL=https://www.baidu.com

BROWSER=chrome
HEADLESS=true
IMPLICIT_WAIT=10
PAGE_LOAD_TIMEOUT=30
SCRIPT_TIMEOUT=10

WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080

LOG_LEVEL=INFO
LOG_DIR=logs/ui_baidu/prod

ALLURE_REPORT_DIR=reports/ui_baidu/prod/allure
ALLURE_HISTORY_DIR=reports/ui_baidu/prod/history
SCREENSHOT_DIR=reports/ui_baidu/prod/screenshots
