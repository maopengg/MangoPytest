# -*- coding: utf-8 -*-
# 百度 UI 测试 - 开发环境配置

ENV=dev
BASE_URL=http://localhost:8080

BROWSER=chrome
HEADLESS=false
IMPLICIT_WAIT=10
PAGE_LOAD_TIMEOUT=30
SCRIPT_TIMEOUT=10

WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080

LOG_LEVEL=DEBUG
LOG_DIR=logs/ui_baidu/dev

ALLURE_REPORT_DIR=reports/ui_baidu/dev/allure
ALLURE_HISTORY_DIR=reports/ui_baidu/dev/history
SCREENSHOT_DIR=reports/ui_baidu/dev/screenshots
